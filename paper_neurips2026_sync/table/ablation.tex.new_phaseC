\begin{table}[!tb]
    \centering
    \renewcommand{\arraystretch}{1.15}
    \setlength{\tabcolsep}{0.55em}
    \caption{Ablation of \ours{}'s two core representation-and-mode axes, SD~v1.4, strict Qwen3-VL eval. \textbf{(Top)} HOW mode: anchor inpainting vs hybrid guidance on Ring-A-Bell with family pack default ($F{=}4$, $K{=}4$). \textbf{(Bottom)} Concept representation: family-grouped ($F{=}4$, $K{=}4$) vs single-pooled exemplars ($N{=}16$), under each mode's best per-concept setting. Best SR (\%) per row; cells shown as \texttt{--} indicate measurements not yet collected.}
    \label{table:ablation}
    \vspace{2pt}
    \small
    \begin{tabular}{lccc}
    \toprule
    \multicolumn{4}{l}{\emph{(a) HOW mode (family pack), Ring-A-Bell (79)}} \\
    \midrule
    \textbf{Mode} & \textbf{SR}$\uparrow$ & \textbf{Full}$\downarrow$ & $\Delta$ vs anchor \\
    \midrule
    Ours (anchor, family) & 93.7 & -- & --              \\
    Ours (hybrid, family) & \textbf{96.2} & -- & \color{green!50!black}{+2.5} \\
    \midrule[\heavyrulewidth]
    \multicolumn{4}{l}{\emph{(b) Family vs single pack ($N{=}16$), across concepts}} \\
    \midrule
    \textbf{Concept} & \textbf{Family} & \textbf{Single} & $\Delta$ \\
    \midrule
    RAB (nudity)     & \textbf{88.6} & 88.6 & 0.0 \\
    MJA Sexual       & 84.0 & \textbf{85.0} & $-$1.0 \\
    MJA Violent      & \textbf{50.0} & 29.0 & \color{green!50!black}{+21.0} \\
    MJA Disturbing   & \textbf{99.0} & 99.0 & 0.0 \\
    MJA Illegal      & \textbf{100.0} & 80.0 & \color{green!50!black}{+20.0} \\
    \bottomrule
    \end{tabular}

    \vspace{0.4em}
    {\footnotesize \textbf{(a)} Hybrid delivers stronger correction when the paired anchor is visually crisp (clothed body for nudity), gaining $+2.5$\%p over anchor on RAB at the cost of an extra anchor forward pass per step; we report both modes throughout because other concepts (\eg, violence, illegal) favor the lighter anchor-inpaint mode---see Table~\ref{table:multi}. \textbf{(b)} Family grouping yields large gains for semantically diverse concepts (MJA Violent $+21$\%p, MJA Illegal $+20$\%p) whose sub-categories differ visually, and is on par for tightly-scoped concepts.}
\end{table}
